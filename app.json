{
  "expo": {
    "name": "brewlab",
    "slug": "brewlab",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "brewlab",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.wgoadri.brewlab"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-status-bar",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a1642cb7-af39-48ac-a65c-22f03b03e175"
      }
    },
    "owner": "wgoadri"
  }
}
